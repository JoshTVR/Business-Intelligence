    CAST(Cliente_Postal    AS NVARCHAR(20))  AS Postal_Code,
    CAST(Cliente_Pais      AS NVARCHAR(100)) AS Country,
    ETLLoad,
    ETLExecution
FROM [Stage_Northwind].[dbo].[Stage_Cliente];</property>

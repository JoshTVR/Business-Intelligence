                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    CAST(Cliente_Codigo    AS NVARCHAR(10))  AS CustumerID_nk,
    CAST(Cliente_Compania  AS NVARCHAR(40))  AS Company_Name,
    CAST(Cliente_Nombre    AS NVARCHAR(30))  AS Contact_Name,
